# PostgreSQL
DATABASE_URL=postgresql+asyncpg://realestate:realestate@localhost:5432/realestate

# Embeddingi
EMBEDDING_DIM=2048

# --- LLM (opcjonalne; bez tych wartości LLM jest wyłączony — działa degradacja) ---
# Domyślny LLM_BASE_URL to OpenRouter; nadpisz dla innego dostawcy OpenAI-compatible.
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=
# LLM_EMBEDDING_MODEL=
# LLM_TIMEOUT_SECONDS=30
# LLM_MAX_RETRIES=2

# --- Geokodowanie adresów -> lat/lon ofert (pinezki na mapie) ---
# Domyślnie włączone, dostawca OpenStreetMap/Nominatim (darmowy, bez klucza).
# GEOCODING_ENABLED=true
# GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
# GEOCODING_USER_AGENT=RealEstateAggregator/1.0 (local tool)
# GEOCODING_MIN_DELAY_SECONDS=1.0
# GEOCODING_TIMEOUT_SECONDS=10.0
